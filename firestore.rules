rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: WhatsApp Group/Channel submission validation ───────────────
    function isValidWhatsAppGroupData() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'link', 'category', 'country', 'language'])
          && d.name is string  && d.name.size() > 0  && d.name.size() <= 60
          && d.link is string
          && (d.link.matches('https://chat[.]whatsapp[.]com/.*')
              || d.link.matches('https://www[.]whatsapp[.]com/channel/.*'))
          && d.category is string && d.category.size() > 0
          && d.country  is string && d.country.size()  > 0
          && d.language is string && d.language.size() > 0
          && (!('description' in d) || (d.description is string && d.description.size() <= 250))
          && (!('tags'        in d) || (d.tags is list  && d.tags.size() <= 20));
    }

    // ─── Helper: Telegram Group/Channel submission validation ───────────────
    function isValidTelegramGroupData() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'link', 'category', 'country', 'language'])
          && d.name is string  && d.name.size() > 0  && d.name.size() <= 60
          && d.link is string  && d.link.size() >= 3 && d.link.size() <= 200
          && d.category is string && d.category.size() > 0
          && d.country  is string && d.country.size()  > 0
          && d.language is string && d.language.size() > 0
          && (!('description' in d) || (d.description is string && d.description.size() <= 250))
          && (!('tags'        in d) || (d.tags is list  && d.tags.size() <= 20));
    }

    // ─── Helper: only iconUrl / reports fields may be updated ──────────────
    function isValidUpdateRequest() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['iconUrl', 'reports']) || changed.size() == 0;
    }

    // ─── Pending WhatsApp submissions ───────────────────────────────────────
    match /whatsapp/{groupId} {
      allow read:   if true;
      allow create: if isValidWhatsAppGroupData();
      allow update: if isValidUpdateRequest();
      allow delete: if true;
    }

    // ─── Pending Telegram submissions ───────────────────────────────────────
    match /telegramGroups/{groupId} {
      allow read:   if true;
      allow create: if isValidTelegramGroupData();
      allow update: if isValidUpdateRequest();
      allow delete: if true;
    }

    // ─── Approved WhatsApp groups/channels (public listing) ─────────────────
    match /ApprovedWA/{docId} {
      allow read:          if true;
      allow create:        if true;
      allow update, delete: if true;
    }

    // ─── Approved Telegram groups/channels (public listing) ─────────────────
    match /ApprovedTG/{docId} {
      allow read:          if true;
      allow create:        if true;
      allow update, delete: if true;
    }

    // ─── Admin login credentials ─────────────────────────────────────────────
    match /credentials/{credentialId} {
      allow read, write: if true;
    }

    // ─── Dropdown options (category / countries / languages) ────────────────
    match /dropdowns/{dropdown} {
      allow read, write: if true;
    }

    // ─── Admin / config documents ────────────────────────────────────────────
    match /admin/{document} {
      allow read, write: if true;
    }

    // ─── Users collection ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if true;
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
